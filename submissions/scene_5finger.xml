<mujoco model="adaptive_dexhand_5finger">
  <compiler angle="radian"/>
  <option timestep="0.001" iterations="50" jacobian="dense">
    <flag constraint="enable" contact="enable"/>
  </option>
  
  <default>
    <geom condim="4" friction="1.5 0.01 0.001"/>
    <joint armature="0.001" damping="3"/>
  </default>
  
  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.3 0.3 0.3"/>
    <global azimuth="200" elevation="-25" offwidth="1280" offheight="720"/>
  </visual>
  
  <asset>
    <material name="red" rgba="0.9 0.15 0.15 1"/>
    <material name="blue" rgba="0.15 0.25 0.9 1"/>
    <material name="green" rgba="0.15 0.75 0.25 1"/>
    <material name="yellow" rgba="0.9 0.85 0.15 1"/>
    <material name="purple" rgba="0.55 0.15 0.8 1"/>
    <material name="orange" rgba="0.95 0.55 0.1 1"/>
    <material name="cyan" rgba="0.1 0.8 0.8 1"/>
    <material name="pink" rgba="0.95 0.4 0.7 1"/>
    <material name="brown" rgba="0.55 0.35 0.15 1"/>
    <material name="gray" rgba="0.5 0.5 0.5 1"/>
    <material name="hand" rgba="0.8 0.6 0.45 1"/>
    <material name="palm_mat" rgba="0.75 0.55 0.4 1"/>
    <material name="table_mat" rgba="0.55 0.45 0.35 1"/>
    <material name="floor_mat" rgba="0.3 0.45 0.3 1"/>
  </asset>
  
  <worldbody>
    <!-- 地板 -->
    <geom name="floor" type="plane" size="2 2 0.01" material="floor_mat"/>
    
    <!-- 桌子 -->
    <body name="table" pos="0 0 0.3">
      <geom name="table_top" type="box" size="0.4 0.4 0.015" material="table_mat" contype="1" conaffinity="1"/>
    </body>
    
    <!-- ======== 10种物体 ======== -->
    <!-- 1. 红球 -->
    <body name="obj_sphere" pos="-0.2 -0.15 0.34">
      <joint name="obj_sphere_j" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.5"/>
      <geom name="g_sphere" type="sphere" size="0.02" material="red" mass="0.03"/>
    </body>
    
    <!-- 2. 蓝立方体 -->
    <body name="obj_cube" pos="-0.1 -0.15 0.335">
      <joint name="obj_cube_j" type="slide" axis="0 0 1" range="-0.335 1.0" damping="0.5"/>
      <geom name="g_cube" type="box" size="0.015 0.015 0.015" material="blue" mass="0.04"/>
    </body>
    
    <!-- 3. 绿圆柱 -->
    <body name="obj_cylinder" pos="0 -0.15 0.34">
      <joint name="obj_cylinder_j" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.5"/>
      <geom name="g_cylinder" type="cylinder" size="0.012 0.025" material="green" mass="0.035"/>
    </body>
    
    <!-- 4. 黄胶囊 -->
    <body name="obj_capsule" pos="0.1 -0.15 0.34">
      <joint name="obj_capsule_j" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.5"/>
      <geom name="g_capsule" type="capsule" fromto="0 0 -0.02 0 0 0.02" size="0.01" material="yellow" mass="0.03"/>
    </body>
    
    <!-- 5. 紫椭球(用sphere缩放模拟) -->
    <body name="obj_ellipsoid" pos="0.2 -0.15 0.34">
      <joint name="obj_ellipsoid_j" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.5"/>
      <geom name="g_ellipsoid" type="sphere" size="0.018" material="purple" mass="0.025"/>
    </body>
    
    <!-- 6. 橙小球 -->
    <body name="obj_small" pos="-0.2 0.05 0.335">
      <joint name="obj_small_j" type="slide" axis="0 0 1" range="-0.335 1.0" damping="0.5"/>
      <geom name="g_small" type="sphere" size="0.012" material="orange" mass="0.015"/>
    </body>
    
    <!-- 7. 青大球 -->
    <body name="obj_big" pos="-0.1 0.05 0.35">
      <joint name="obj_big_j" type="slide" axis="0 0 1" range="-0.35 1.0" damping="0.5"/>
      <geom name="g_big" type="sphere" size="0.03" material="cyan" mass="0.06"/>
    </body>
    
    <!-- 8. 粉色长方体 -->
    <body name="obj_rect" pos="0 0.05 0.335">
      <joint name="obj_rect_j" type="slide" axis="0 0 1" range="-0.335 1.0" damping="0.5"/>
      <geom name="g_rect" type="box" size="0.025 0.01 0.01" material="pink" mass="0.035"/>
    </body>
    
    <!-- 9. 棕色小圆柱 -->
    <body name="obj_small_cyl" pos="0.1 0.05 0.335">
      <joint name="obj_small_cyl_j" type="slide" axis="0 0 1" range="-0.335 1.0" damping="0.5"/>
      <geom name="g_small_cyl" type="cylinder" size="0.008 0.02" material="brown" mass="0.025"/>
    </body>
    
    <!-- 10. 灰色大立方体 -->
    <body name="obj_big_cube" pos="0.2 0.05 0.34">
      <joint name="obj_big_cube_j" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.5"/>
      <geom name="g_big_cube" type="box" size="0.02 0.02 0.02" material="gray" mass="0.05"/>
    </body>
    
    <!-- ======== 5指灵巧手 ======== -->
    <body name="base" pos="0 0 0.65">
      <geom type="box" size="0.04 0.04 0.02" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      
      <!-- 垂直滑轨 -->
      <body name="arm">
        <joint name="z" type="slide" axis="0 0 -1" range="0 0.35"/>
        <geom type="box" size="0.025 0.025 0.012" rgba="0.4 0.4 0.4 1" contype="0" conaffinity="0"/>
        
        <!-- 手掌 -->
        <body name="palm" pos="0 0 -0.02">
          <geom name="palm_g" type="box" size="0.03 0.035 0.008" material="palm_mat" contype="1" conaffinity="1"/>
          
          <!-- 拇指 (正面偏右) -->
          <body name="f_thumb" pos="0.03 0.02 -0.008">
            <joint name="j_thumb1" type="hinge" axis="0 1 0" range="0 1.5"/>
            <geom type="capsule" fromto="0 0 0 0.015 0.01 -0.025" size="0.007" material="hand"/>
            <body name="f_thumb_t" pos="0.015 0.01 -0.025">
              <joint name="j_thumb2" type="hinge" axis="0 1 0" range="0 1.2"/>
              <geom type="capsule" fromto="0 0 0 0.01 0.008 -0.018" size="0.006" material="hand"/>
              <body name="f_thumb_tip" pos="0.01 0.008 -0.018">
                <joint name="j_thumb3" type="hinge" axis="0 1 0" range="0 1.0"/>
                <geom type="capsule" fromto="0 0 0 0.008 0.005 -0.012" size="0.005" material="hand"/>
                <site name="s_thumb" pos="0.008 0.005 -0.012"/>
              </body>
            </body>
          </body>
          
          <!-- 食指 -->
          <body name="f1" pos="0.018 0.02 -0.008">
            <joint name="j1" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.03" size="0.006" material="hand"/>
            <body name="f1t" pos="0 0.01 -0.03">
              <joint name="j1t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand"/>
              <site name="s1" pos="0 0.008 -0.025"/>
            </body>
          </body>
          
          <!-- 中指 -->
          <body name="f2" pos="0 0.022 -0.008">
            <joint name="j2" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.012 -0.035" size="0.006" material="hand"/>
            <body name="f2t" pos="0 0.012 -0.035">
              <joint name="j2t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.01 -0.028" size="0.005" material="hand"/>
              <site name="s2" pos="0 0.01 -0.028"/>
            </body>
          </body>
          
          <!-- 无名指 -->
          <body name="f3" pos="-0.018 0.02 -0.008">
            <joint name="j3" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.03" size="0.005" material="hand"/>
            <body name="f3t" pos="0 0.01 -0.03">
              <joint name="j3t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.022" size="0.004" material="hand"/>
              <site name="s3" pos="0 0.008 -0.022"/>
            </body>
          </body>
          
          <!-- 小指 -->
          <body name="f4" pos="-0.03 0.018 -0.008">
            <joint name="j4" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand"/>
            <body name="f4t" pos="0 0.008 -0.025">
              <joint name="j4t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.006 -0.02" size="0.004" material="hand"/>
              <site name="s4" pos="0 0.006 -0.02"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  
  <!-- 5个触觉传感器 -->
  <sensor>
    <touch name="t_thumb" site="s_thumb"/>
    <touch name="t1" site="s1"/>
    <touch name="t2" site="s2"/>
    <touch name="t3" site="s3"/>
    <touch name="t4" site="s4"/>
  </sensor>
  
  <!-- 15个执行器 (拇指3关节x1 + 4指x(1基+1尖)) -->
  <actuator>
    <position name="az" joint="z" kp="800" kv="80"/>
    <position name="a_thumb1" joint="j_thumb1" kp="150" kv="15"/>
    <position name="a_thumb2" joint="j_thumb2" kp="120" kv="12"/>
    <position name="a_thumb3" joint="j_thumb3" kp="100" kv="10"/>
    <position name="a1" joint="j1" kp="150" kv="15"/>
    <position name="a1t" joint="j1t" kp="120" kv="12"/>
    <position name="a2" joint="j2" kp="150" kv="15"/>
    <position name="a2t" joint="j2t" kp="120" kv="12"/>
    <position name="a3" joint="j3" kp="150" kv="15"/>
    <position name="a3t" joint="j3t" kp="120" kv="12"/>
    <position name="a4" joint="j4" kp="150" kv="15"/>
    <position name="a4t" joint="j4t" kp="120" kv="12"/>
  </actuator>
</mujoco>
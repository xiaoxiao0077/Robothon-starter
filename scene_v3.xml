<mujoco model="dexhand_v3">
  <compiler angle="radian"/>
  <option timestep="0.002" iterations="30"/>
  <default><geom condim="4" friction="2.0 0.01 0.001"/></default>
  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.3 0.3 0.3"/>
    <global azimuth="210" elevation="-30" offwidth="1280" offheight="720"/>
  </visual>
  <asset>
    <material name="red" rgba="0.9 0.15 0.15 1"/>
    <material name="blue" rgba="0.15 0.25 0.9 1"/>
    <material name="green" rgba="0.15 0.75 0.25 1"/>
    <material name="yellow" rgba="0.9 0.85 0.15 1"/>
    <material name="purple" rgba="0.55 0.15 0.8 1"/>
    <material name="orange" rgba="0.95 0.55 0.1 1"/>
    <material name="cyan" rgba="0.1 0.8 0.8 1"/>
    <material name="pink" rgba="0.95 0.4 0.7 1"/>
    <material name="brown" rgba="0.55 0.35 0.15 1"/>
    <material name="gray" rgba="0.5 0.5 0.5 1"/>
    <material name="hand" rgba="0.8 0.6 0.45 1"/>
    <material name="palm_mat" rgba="0.75 0.55 0.4 1"/>
  </asset>
  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.01" rgba="0.3 0.45 0.3 1"/>
    <body name="table" pos="0 0 0.3">
      <geom type="box" size="0.5 0.5 0.015" rgba="0.55 0.45 0.35 1" contype="1" conaffinity="1"/>
    </body>
    <!-- 物体 (slide joint, z only) -->
    <body name="obj" pos="0 0 0.34">
      <joint name="obj_z" type="slide" axis="0 0 1" range="-0.34 1.0" damping="0.3"/>
      <geom name="obj_g" type="sphere" size="0.025" material="red" mass="0.05"/>
    </body>
    <!-- 5指灵巧手 + z轴滑轨 -->
    <body name="rail" pos="0 0 0.65">
      <geom type="box" size="0.04 0.04 0.02" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      <body name="arm">
        <joint name="z_slide" type="slide" axis="0 0 -1" range="0 0.30" damping="10"/>
        <geom type="cylinder" size="0.015 0.01" rgba="0.4 0.4 0.4 1" contype="0" conaffinity="0"/>
        <body name="palm" pos="0 0 -0.01">
          <geom name="palm_g" type="box" size="0.035 0.04 0.008" material="palm_mat" contype="2" conaffinity="2"/>
          <!-- 拇指 (右侧) -->
          <body name="thumb_b" pos="0.035 0.025 -0.008">
            <joint name="thumb_j1" type="hinge" axis="0 1 0" range="0 1.5"/>
            <geom type="capsule" fromto="0 0 0 0 0.015 -0.025" size="0.007" material="hand" contype="2" conaffinity="2"/>
            <body name="thumb_m" pos="0 0.015 -0.025">
              <joint name="thumb_j2" type="hinge" axis="0 1 0" range="0 1.2"/>
              <geom type="capsule" fromto="0 0 0 0 0.01 -0.02" size="0.006" material="hand" contype="2" conaffinity="2"/>
              <body name="thumb_t" pos="0 0.01 -0.02">
                <joint name="thumb_j3" type="hinge" axis="0 1 0" range="0 1.0"/>
                <geom type="capsule" fromto="0 0 0 0 0.008 -0.015" size="0.005" material="hand" contype="2" conaffinity="2"/>
                <site name="s_thumb" pos="0 0.008 -0.015"/>
              </body>
            </body>
          </body>
          <!-- 食指 -->
          <body name="f1_b" pos="0.02 0.025 -0.008">
            <joint name="j1" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.032" size="0.006" material="hand" contype="2" conaffinity="2"/>
            <body name="f1_t" pos="0 0.01 -0.032">
              <joint name="j1t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand" contype="2" conaffinity="2"/>
              <site name="s1" pos="0 0.008 -0.025"/>
            </body>
          </body>
          <!-- 中指 -->
          <body name="f2_b" pos="0.005 0.027 -0.008">
            <joint name="j2" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.012 -0.035" size="0.006" material="hand" contype="2" conaffinity="2"/>
            <body name="f2_t" pos="0 0.012 -0.035">
              <joint name="j2t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.01 -0.028" size="0.005" material="hand" contype="2" conaffinity="2"/>
              <site name="s2" pos="0 0.01 -0.028"/>
            </body>
          </body>
          <!-- 无名指 -->
          <body name="f3_b" pos="-0.012 0.025 -0.008">
            <joint name="j3" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.03" size="0.005" material="hand" contype="2" conaffinity="2"/>
            <body name="f3_t" pos="0 0.01 -0.03">
              <joint name="j3t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.022" size="0.004" material="hand" contype="2" conaffinity="2"/>
              <site name="s3" pos="0 0.008 -0.022"/>
            </body>
          </body>
          <!-- 小指 -->
          <body name="f4_b" pos="-0.028 0.022 -0.008">
            <joint name="j4" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand" contype="2" conaffinity="2"/>
            <body name="f4_t" pos="0 0.008 -0.025">
              <joint name="j4t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.006 -0.02" size="0.004" material="hand" contype="2" conaffinity="2"/>
              <site name="s4" pos="0 0.006 -0.02"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <sensor>
    <touch name="t_thumb" site="s_thumb"/>
    <touch name="t1" site="s1"/>
    <touch name="t2" site="s2"/>
    <touch name="t3" site="s3"/>
    <touch name="t4" site="s4"/>
  </sensor>
  <actuator>
    <position name="az" joint="z_slide" kp="800" kv="80"/>
    <position name="a_thumb1" joint="thumb_j1" kp="150" kv="15"/>
    <position name="a_thumb2" joint="thumb_j2" kp="120" kv="12"/>
    <position name="a_thumb3" joint="thumb_j3" kp="100" kv="10"/>
    <position name="a1" joint="j1" kp="150" kv="15"/>
    <position name="a1t" joint="j1t" kp="120" kv="12"/>
    <position name="a2" joint="j2" kp="150" kv="15"/>
    <position name="a2t" joint="j2t" kp="120" kv="12"/>
    <position name="a3" joint="j3" kp="150" kv="15"/>
    <position name="a3t" joint="j3t" kp="120" kv="12"/>
    <position name="a4" joint="j4" kp="150" kv="15"/>
    <position name="a4t" joint="j4t" kp="120" kv="12"/>
  </actuator>
</mujoco>

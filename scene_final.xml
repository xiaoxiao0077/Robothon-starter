<mujoco model="dexhand_final">
  <compiler angle="radian"/>
  <option timestep="0.001" iterations="50"/>
  <default>
    <geom condim="4" friction="1.5 0.01 0.001"/>
    <joint damping="2"/>
  </default>
  <visual>
    <headlight diffuse="0.7 0.7 0.7" ambient="0.3 0.3 0.3"/>
    <global azimuth="210" elevation="-30" offwidth="1280" offheight="720"/>
  </visual>
  <asset>
    <material name="red" rgba="0.9 0.15 0.15 1"/>
    <material name="blue" rgba="0.15 0.25 0.9 1"/>
    <material name="green" rgba="0.15 0.75 0.25 1"/>
    <material name="yellow" rgba="0.9 0.85 0.15 1"/>
    <material name="purple" rgba="0.55 0.15 0.8 1"/>
    <material name="orange" rgba="0.95 0.55 0.1 1"/>
    <material name="cyan" rgba="0.1 0.8 0.8 1"/>
    <material name="pink" rgba="0.95 0.4 0.7 1"/>
    <material name="brown" rgba="0.55 0.35 0.15 1"/>
    <material name="gray" rgba="0.5 0.5 0.5 1"/>
    <material name="hand_mat" rgba="0.8 0.6 0.45 1"/>
    <material name="palm_mat" rgba="0.75 0.55 0.4 1"/>
  </asset>
  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.3 0.45 0.3 1"/>
    <body name="table" pos="0 0 0.4">
      <geom type="box" size="0.5 0.5 0.015" rgba="0.55 0.45 0.35 1"/>
    </body>
    <!-- 物体 -->
    <body name="obj" pos="0 0 0.435">
      <freejoint name="obj_j"/>
      <geom name="obj_g" type="sphere" size="0.025" material="red" mass="0.05"/>
    </body>
    <!-- 手掌 + z轴升降 + 5指 -->
    <body name="base" pos="0 0 0.85">
      <geom type="box" size="0.05 0.05 0.02" rgba="0.3 0.3 0.3 1" contype="0" conaffinity="0"/>
      <body name="slider">
        <joint name="z" type="slide" axis="0 0 -1" range="0 0.45" damping="20"/>
        <geom type="cylinder" size="0.02 0.015" rgba="0.4 0.4 0.4 1" contype="0" conaffinity="0"/>
        <body name="palm" pos="0 0 -0.015">
          <geom type="box" size="0.035 0.04 0.008" material="palm_mat" contype="0" conaffinity="0"/>
          <!-- 拇指 -->
          <body name="thumb1" pos="0.035 0.02 -0.008">
            <joint name="tj1" type="hinge" axis="0 1 0" range="0 1.5"/>
            <geom type="capsule" fromto="0 0 0 0.015 0.01 -0.025" size="0.007" material="hand_mat"/>
            <body name="thumb2" pos="0.015 0.01 -0.025">
              <joint name="tj2" type="hinge" axis="0 1 0" range="0 1.2"/>
              <geom type="capsule" fromto="0 0 0 0.01 0.008 -0.02" size="0.006" material="hand_mat"/>
              <body name="thumb3" pos="0.01 0.008 -0.02">
                <joint name="tj3" type="hinge" axis="0 1 0" range="0 1.0"/>
                <geom type="capsule" fromto="0 0 0 0.008 0.005 -0.015" size="0.005" material="hand_mat"/>
                <site name="st" pos="0.008 0.005 -0.015"/>
              </body>
            </body>
          </body>
          <!-- 食指 -->
          <body name="f1a" pos="0.018 0.02 -0.008">
            <joint name="j1" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.032" size="0.006" material="hand_mat"/>
            <body name="f1b" pos="0 0.01 -0.032">
              <joint name="j1t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand_mat"/>
              <site name="s1" pos="0 0.008 -0.025"/>
            </body>
          </body>
          <!-- 中指 -->
          <body name="f2a" pos="0.003 0.023 -0.008">
            <joint name="j2" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.012 -0.035" size="0.006" material="hand_mat"/>
            <body name="f2b" pos="0 0.012 -0.035">
              <joint name="j2t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.01 -0.028" size="0.005" material="hand_mat"/>
              <site name="s2" pos="0 0.01 -0.028"/>
            </body>
          </body>
          <!-- 无名指 -->
          <body name="f3a" pos="-0.013 0.02 -0.008">
            <joint name="j3" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.01 -0.03" size="0.005" material="hand_mat"/>
            <body name="f3b" pos="0 0.01 -0.03">
              <joint name="j3t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.008 -0.022" size="0.004" material="hand_mat"/>
              <site name="s3" pos="0 0.008 -0.022"/>
            </body>
          </body>
          <!-- 小指 -->
          <body name="f4a" pos="-0.028 0.018 -0.008">
            <joint name="j4" type="hinge" axis="-1 0 0" range="0 2"/>
            <geom type="capsule" fromto="0 0 0 0 0.008 -0.025" size="0.005" material="hand_mat"/>
            <body name="f4b" pos="0 0.008 -0.025">
              <joint name="j4t" type="hinge" axis="-1 0 0" range="0 1.8"/>
              <geom type="capsule" fromto="0 0 0 0 0.006 -0.02" size="0.004" material="hand_mat"/>
              <site name="s4" pos="0 0.006 -0.02"/>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <sensor>
    <touch name="t_thumb" site="st"/>
    <touch name="t1" site="s1"/>
    <touch name="t2" site="s2"/>
    <touch name="t3" site="s3"/>
    <touch name="t4" site="s4"/>
  </sensor>
  <actuator>
    <position name="az" joint="z" kp="2000" kv="200"/>
    <position name="at1" joint="tj1" kp="200" kv="20"/>
    <position name="at2" joint="tj2" kp="150" kv="15"/>
    <position name="at3" joint="tj3" kp="120" kv="12"/>
    <position name="a1" joint="j1" kp="200" kv="20"/>
    <position name="a1t" joint="j1t" kp="150" kv="15"/>
    <position name="a2" joint="j2" kp="200" kv="20"/>
    <position name="a2t" joint="j2t" kp="150" kv="15"/>
    <position name="a3" joint="j3" kp="200" kv="20"/>
    <position name="a3t" joint="j3t" kp="150" kv="15"/>
    <position name="a4" joint="j4" kp="200" kv="20"/>
    <position name="a4t" joint="j4t" kp="150" kv="15"/>
  </actuator>
</mujoco>
